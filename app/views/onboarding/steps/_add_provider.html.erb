<%= form_with(url: onboarding_index_path, method: :patch, class: "space-y-4") do |f| %>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-sm font-medium text-gray-700">First Name</label>
      <%= text_field_tag "provider[first_name]", nil, placeholder: "Jane",
        class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Last Name</label>
      <%= text_field_tag "provider[last_name]", nil, placeholder: "Smith",
        class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700">Title</label>
    <%= text_field_tag "provider[title]", nil, placeholder: "MD, DDS, DO...",
      class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>
  <%= submit_tag "Add Provider & Continue",
    class: "flex w-full justify-center rounded-xl bg-teal-600 px-4 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer transition" %>
<% end %>
