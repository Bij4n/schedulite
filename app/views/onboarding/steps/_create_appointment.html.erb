<div class="text-center py-4">
  <div class="w-16 h-16 rounded-full bg-teal-50 flex items-center justify-center mx-auto mb-4">
    <svg class="w-8 h-8 text-teal-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
    </svg>
  </div>
  <p class="text-sm text-gray-500 mb-6">You can create your first appointment now, or do it later from the dashboard.</p>

  <div class="space-y-3">
    <%= link_to "Create an Appointment", new_appointment_path,
      class: "flex w-full justify-center rounded-xl bg-teal-600 px-4 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 transition" %>

    <%= form_with(url: onboarding_index_path, method: :patch) do %>
      <%= submit_tag "Go to Dashboard",
        class: "flex w-full justify-center rounded-xl bg-white px-4 py-3.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 cursor-pointer transition" %>
    <% end %>
  </div>
</div>
