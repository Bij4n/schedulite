<%= form_with(url: onboarding_index_path, method: :patch, class: "space-y-4") do |f| %>
  <div>
    <label class="block text-sm font-medium text-gray-700">Practice Address</label>
    <%= text_field_tag "tenant[address]", current_user.tenant.address,
      placeholder: "123 Main St",
      class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>
  <div class="grid grid-cols-3 gap-3">
    <div>
      <label class="block text-sm font-medium text-gray-700">City</label>
      <%= text_field_tag "tenant[city]", current_user.tenant.city,
        class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">State</label>
      <%= text_field_tag "tenant[state]", current_user.tenant.state,
        class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">ZIP</label>
      <%= text_field_tag "tenant[zip]", current_user.tenant.zip,
        class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
  </div>
  <%= submit_tag "Continue",
    class: "flex w-full justify-center rounded-xl bg-teal-600 px-4 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer transition" %>
<% end %>
