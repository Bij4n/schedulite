<div class="flex flex-col items-center gap-1 text-xs text-gray-400">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-teal-600 hover:text-teal-500" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-teal-600 hover:text-teal-500" %>
  <% end %>
</div>
