<h2>Time Off Request</h2>

<p>Hi <%= @manager.first_name %>,</p>

<p><strong><%= @requester.full_name %></strong> has submitted a time off request:</p>

<table style="margin: 16px 0; border-collapse: collapse;">
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">From</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @start_date.strftime("%A, %B %-d, %Y") %></td>
  </tr>
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">To</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @end_date.strftime("%A, %B %-d, %Y") %></td>
  </tr>
  <% if @reason.present? %>
    <tr>
      <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">Reason</td>
      <td style="padding: 4px 0;"><%= @reason %></td>
    </tr>
  <% end %>
</table>

<p style="font-size: 14px;">Please log in to Schedulite to approve or decline this request.</p>

<p style="font-size: 12px; color: #9ca3af; margin-top: 24px;">— Schedulite</p>
