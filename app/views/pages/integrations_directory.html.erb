<%= render "pages/public_nav" %>

<div class="pt-28 pb-24 px-6">
  <div class="mx-auto max-w-3xl">

    <!-- Header -->
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Supported Systems</h1>
      <p class="mt-3 text-lg text-gray-500 max-w-xl mx-auto">Schedulite connects to the tools your practice already uses. One platform, every calendar, every EHR.</p>
    </div>

    <!-- How we integrate -->
    <div class="mb-16 rounded-2xl bg-gray-50 border border-gray-200 p-8">
      <h2 class="text-lg font-bold text-gray-900 mb-4">How integration works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div>
          <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
            <span class="text-xs font-bold text-teal-600">1</span>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Standards-based</h3>
          <p class="mt-1 text-xs text-gray-500 leading-relaxed">Any EHR that supports FHIR R4 works automatically. No custom build needed. Just connect with your credentials.</p>
        </div>
        <div>
          <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
            <span class="text-xs font-bold text-teal-600">2</span>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Direct adapters</h3>
          <p class="mt-1 text-xs text-gray-500 leading-relaxed">For systems with their own API, we build dedicated adapters that sync appointments and handle webhooks.</p>
        </div>
        <div>
          <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
            <span class="text-xs font-bold text-teal-600">3</span>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Calendar sync</h3>
          <p class="mt-1 text-xs text-gray-500 leading-relaxed">Any calendar that exports .ics feeds works. Each provider can use the calendar they prefer.</p>
        </div>
      </div>
    </div>

    <!-- FHIR R4 compatible EHRs -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-lg font-bold text-gray-900">EHR Systems</h2>
        <span class="text-[10px] font-semibold rounded-full bg-teal-50 text-teal-600 px-2 py-0.5 uppercase tracking-wide">Via FHIR R4</span>
      </div>
      <p class="text-sm text-gray-500 mb-5">These systems support FHIR R4, which means they work automatically with Schedulite's standards-based adapter. No custom integration needed.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% [
          "Epic", "Cerner (Oracle Health)", "Athenahealth",
          "Greenway Health", "eClinicalWorks", "NextGen Healthcare",
          "Allscripts (Veradigm)", "Practice Fusion", "DrChrono",
          "Meditech", "CPSI", "Modernizing Medicine",
          "CareCloud", "AdvancedMD", "Elation Health",
          "Amazing Charts", "Azalea Health", "Praxis EMR",
          "TherapyNotes", "Valant", "Nexus Clinical",
          "OceanMD", "TELUS PS Suite", "OSCAR / Oscar Pro", "Accuro",
          "Aprima", "Office Practicum", "EpicCare Ambulatory",
          "MEDHOST", "Healthland", "Evident",
          "MEDITAB", "WRS Health", "iSalus",
          "MicroMD", "Office Ally", "Compulink",
          "ChartLogic", "Sevocity", "Practice EHR",
          "Iris Intelligence", "Bizmatics PrognoCIS", "MDConnection",
          "Eyefinity", "RevolutionEHR", "Crystal PM",
          "Dentrix", "Eaglesoft", "Curve Dental",
          "Carestream Dental", "ABELDent", "ClearDent",
          "Power Diary", "Halaxy", "Best Practice (Bp)",
          "MedicalDirector", "Clinic to Cloud", "Genie Solutions",
          "Pracsoft", "Zedmed", "Visma Avendra",
          "EMIS Health", "TPP SystmOne", "Vision Health (Cegedim)",
          "Wolf EMR", "Med Access", "QHR Accuro EMR",
          "InputHealth (WELL Health)", "PointClickCare", "MatrixCare"
        ].each do |name| %>
          <div class="rounded-xl bg-white border border-gray-200 px-4 py-3 flex items-center gap-3">
            <svg class="w-4 h-4 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            <span class="text-sm font-medium text-gray-900"><%= name %></span>
          </div>
        <% end %>
      </div>
      <p class="mt-3 text-xs text-gray-400">Any system that implements the HL7 FHIR R4 standard and SMART-on-FHIR OAuth is compatible — even if it's not listed above.</p>
    </section>

    <!-- Calendars & Scheduling -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-lg font-bold text-gray-900">Calendars & Scheduling</h2>
        <span class="text-[10px] font-semibold rounded-full bg-blue-50 text-blue-600 px-2 py-0.5 uppercase tracking-wide">Direct Adapter</span>
      </div>
      <p class="text-sm text-gray-500 mb-5">Connect your team's preferred calendar. Each provider and staff member can use a different one.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% [
          "Google Calendar", "Microsoft Outlook 365", "Apple Calendar (iCloud)",
          "Calendly", "Cal.com", "Acuity Scheduling",
          "Zoho Bookings", "Setmore", "iCal Feed (any .ics)",
          "Square Appointments", "Booksy", "SimplyBook.me",
          "YouCanBook.me", "Doodle", "TidyCal",
          "HubSpot Meetings", "Microsoft Bookings", "Doctolib",
          "Zocdoc", "Solv Health", "MyChart Scheduling",
          "Vagaro", "Mindbody", "GReminders",
          "Appointy", "10to8", "Bookafy",
          "Schedulicity", "GoReminders", "Fons",
          "FullSlate", "Picktime", "Reservio",
          "Sign In Scheduling (10to8)", "Setster", "OnceHub",
          "Fantastical (CalDAV)", "Fastmail Calendar (CalDAV)", "Proton Calendar"
        ].each do |name| %>
          <div class="rounded-xl bg-white border border-gray-200 px-4 py-3 flex items-center gap-3">
            <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            <span class="text-sm font-medium text-gray-900"><%= name %></span>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Practice Management -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-lg font-bold text-gray-900">Practice Management</h2>
        <span class="text-[10px] font-semibold rounded-full bg-purple-50 text-purple-600 px-2 py-0.5 uppercase tracking-wide">Direct Adapter</span>
      </div>
      <p class="text-sm text-gray-500 mb-5">Specialty practice management systems with dedicated integrations.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% [
          "Jane App", "SimplePractice", "NexHealth",
          "Kareo / Tebra", "Open Dental", "DrChrono",
          "Cliniko", "ChiroTouch", "PracticeSuite",
          "ClinicSense", "WebPT", "TheraNest",
          "TheraBill", "Procentive", "ICANotes",
          "Sigmund AURA", "Qualifacts CareLogic", "Welligent",
          "Netsmart myAvatar", "Credible Behavioral Health", "Therapy Brands",
          "Procare Solutions", "Office Practicum (Pediatrics)", "PCC Pediatrics",
          "Veterinary: ezyVet", "Veterinary: AVImark", "Veterinary: Cornerstone",
          "Vetspire", "Provet Cloud", "DaySmart Vet",
          "Optosys (Optometry)", "Crystal PM (Optometry)", "MaximEyes",
          "Compulink Eyecare", "MyVision Express", "OD Link",
          "Yocale", "Genbook", "Booker (Mindbody)",
          "Salonized", "Phorest", "Boulevard",
          "Massage Book", "ClinicSoftware", "Insight Salon Software",
          "Cliniconex", "MDsuite", "Athenanet (Collaborator)",
          "Brightree", "Kinnser (WellSky)", "Axxess",
          "Homecare Homebase", "MatrixCare Home Health", "Clinicient Insight",
          "Net Health Therapy", "Raintree Systems", "TheraOffice",
          "PtEverywhere", "Prompt EMR", "MWTherapy"
        ].each do |name| %>
          <div class="rounded-xl bg-white border border-gray-200 px-4 py-3 flex items-center gap-3">
            <svg class="w-4 h-4 text-purple-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            <span class="text-sm font-medium text-gray-900"><%= name %></span>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Don't see yours? — full card at bottom of list -->
    <section id="dont-see-yours" class="rounded-2xl bg-gray-900 p-8 text-center">
      <h2 class="text-xl font-bold text-white">Don't see your system?</h2>
      <p class="mt-2 text-sm text-gray-400 max-w-md mx-auto">If your EHR supports FHIR R4, it already works. If it doesn't, we can build a custom adapter. Most take less than a week.</p>
      <div class="mt-6">
        <a href="mailto:hello@schedulite.io" class="inline-block rounded-full bg-teal-600 px-6 py-3 text-sm font-semibold text-white hover:bg-teal-500 transition">
          Contact Us — hello@schedulite.io
        </a>
      </div>
    </section>

  </div>
</div>

<!-- Floating "Don't see yours?" CTA — follows on scroll -->
<div id="floating-cta" class="fixed z-40 pointer-events-none opacity-0 transition-all duration-500 ease-out
                              bottom-4 left-4 right-4
                              sm:left-auto sm:right-6 sm:bottom-6 sm:max-w-xs"
     style="transform: translateY(20px);">
  <div class="pointer-events-auto rounded-2xl bg-gray-900 border border-gray-800 shadow-2xl shadow-gray-900/40 p-5 backdrop-blur-xl">
    <div class="flex items-start gap-3">
      <div class="w-9 h-9 rounded-xl bg-teal-500/10 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="text-sm font-bold text-white leading-snug">Don't see your system?</h3>
        <p class="mt-1 text-xs text-gray-400 leading-relaxed">We build custom adapters in under a week.</p>
        <a href="mailto:hello@schedulite.io" class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold text-teal-400 hover:text-teal-300 transition">
          Contact us
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
      <button id="floating-cta-dismiss" type="button" aria-label="Dismiss" class="text-gray-500 hover:text-gray-300 transition shrink-0 -mt-1 -mr-1 p-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    const cta = document.getElementById('floating-cta');
    const dismiss = document.getElementById('floating-cta-dismiss');
    const anchor = document.getElementById('dont-see-yours');
    if (!cta || !anchor) return;

    let dismissed = sessionStorage.getItem('schedulite-cta-dismissed') === '1';
    let originalInView = false;
    let scrolledPastHero = false;

    const show = () => {
      cta.style.opacity = '1';
      cta.style.transform = 'translateY(0)';
    };
    const hide = () => {
      cta.style.opacity = '0';
      cta.style.transform = 'translateY(20px)';
    };

    const update = () => {
      if (dismissed || originalInView || !scrolledPastHero) {
        hide();
      } else {
        show();
      }
    };

    // Show only after the user scrolls past ~400px
    window.addEventListener('scroll', () => {
      scrolledPastHero = window.scrollY > 400;
      update();
    }, { passive: true });

    // Hide when the static "Don't see yours?" section is in view
    const obs = new IntersectionObserver((entries) => {
      originalInView = entries[0].isIntersecting;
      update();
    }, { threshold: 0.2 });
    obs.observe(anchor);

    dismiss.addEventListener('click', () => {
      dismissed = true;
      sessionStorage.setItem('schedulite-cta-dismissed', '1');
      hide();
    });
  })();
</script>
