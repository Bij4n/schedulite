<!-- ====== NAV ====== -->
<nav class="fixed top-0 inset-x-0 z-50 bg-white/70 backdrop-blur-xl border-b border-gray-100/60">
  <div class="mx-auto max-w-5xl px-6 py-3 flex items-center justify-between">
    <span class="text-lg font-bold tracking-tight text-gray-900">schedulite</span>
    <div class="flex items-center gap-2">
      <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-500 hover:text-gray-900 transition px-3 py-1.5" %>
      <%= link_to "Get Started", register_path, class: "rounded-full bg-gray-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-gray-800 transition" %>
    </div>
  </div>
</nav>

<!-- ====== HERO ====== -->
<section class="relative pt-36 pb-28 px-6 overflow-hidden">
  <div class="hero-glow"></div>

  <div class="mx-auto max-w-3xl text-center relative z-10">
    <h1 class="text-[2.75rem] sm:text-6xl lg:text-[4.25rem] font-extrabold tracking-[-0.03em] leading-[1.06] text-gray-900">
      Schedules change.<br>
      <span class="grad">Your patients should know.</span>
    </h1>

    <p class="mt-7 text-lg sm:text-xl text-gray-400 max-w-xl mx-auto leading-relaxed font-light">
      Doctors run behind. Emergencies happen. Schedulite coordinates between your providers, staff, and patients in real time — so no one drives an hour to sit in the dark.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
      <%= link_to register_path, class: "rounded-full bg-teal-600 px-7 py-3.5 text-sm font-semibold text-white hover:bg-teal-500 transition cta-glow" do %>
        Start Free — No Credit Card
      <% end %>
      <a href="#how" class="text-sm text-gray-400 hover:text-gray-600 transition px-4 py-3">How it works &darr;</a>
    </div>
  </div>
</section>

<!-- ====== SMS MOCKUP ====== -->
<section class="pb-24 px-6">
  <div class="mx-auto max-w-sm">
    <div class="rounded-3xl bg-gray-950 p-6 shadow-2xl shadow-gray-900/20 drift">
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></div>
          <span class="text-xs text-gray-500 font-medium">Schedulite</span>
        </div>
        <span class="text-[10px] text-gray-600">Today</span>
      </div>
      <div class="space-y-3">
        <!-- Reminder before they leave home -->
        <div class="sms-bubble flex justify-end">
          <div>
            <div class="rounded-2xl rounded-br-md bg-teal-600 text-white px-4 py-2.5 text-[13px] max-w-[260px] leading-relaxed">
              Hi Sarah, reminder: your 2:30 PM appointment with Dr. Patel is on track. See you soon!
            </div>
            <p class="text-[10px] text-gray-600 text-right mt-1 mr-1">12:30 PM</p>
          </div>
        </div>
        <!-- Schedule changes — proactive alert -->
        <div class="sms-bubble flex justify-end">
          <div>
            <div class="rounded-2xl rounded-br-md bg-teal-600 text-white px-4 py-2.5 text-[13px] max-w-[260px] leading-relaxed">
              Heads up — Dr. Patel is running about 20 min behind due to an earlier procedure. No need to rush. We'll keep you posted.
            </div>
            <p class="text-[10px] text-gray-600 text-right mt-1 mr-1">1:47 PM</p>
          </div>
        </div>
        <!-- Patient makes a decision -->
        <div class="sms-bubble flex justify-start">
          <div>
            <div class="rounded-2xl rounded-bl-md bg-gray-800 text-gray-200 px-4 py-2.5 text-[13px] max-w-[220px]">
              Thanks for letting me know. I'll leave a little later then.
            </div>
            <p class="text-[10px] text-gray-600 mt-1 ml-1">1:48 PM</p>
          </div>
        </div>
        <!-- Checked in -->
        <div class="sms-bubble flex justify-end">
          <div>
            <div class="rounded-2xl rounded-br-md bg-teal-600 text-white px-4 py-2.5 text-[13px] max-w-[260px] leading-relaxed">
              You're checked in! 1 patient ahead of you. Estimated wait: ~10 min.
            </div>
            <p class="text-[10px] text-gray-600 text-right mt-1 mr-1">2:42 PM</p>
          </div>
        </div>
        <!-- You're up -->
        <div class="sms-bubble flex justify-end">
          <div>
            <div class="rounded-2xl rounded-br-md bg-teal-600 text-white px-4 py-2.5 text-[13px] max-w-[260px] leading-relaxed">
              You're next! Please head to the front desk.
            </div>
            <p class="text-[10px] text-gray-600 text-right mt-1 mr-1">2:51 PM</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ====== GLOW DIVIDER ====== -->
<div class="glow-line mx-auto max-w-xl"></div>

<!-- ====== HOW IT WORKS ====== -->
<section id="how" class="py-28 px-6">
  <div class="mx-auto max-w-4xl">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-16">
      <div class="reveal">
        <span class="text-xs font-bold text-teal-600 tracking-widest uppercase">01</span>
        <h3 class="mt-3 text-xl font-bold text-gray-900 leading-snug">Providers connect their calendars</h3>
        <p class="mt-2 text-sm text-gray-400 leading-relaxed">Each doctor, NP, or therapist syncs their own calendar — Google, Outlook, Epic, Athena, whatever they use. Schedulite watches for changes.</p>
      </div>
      <div class="reveal reveal-delay-1">
        <span class="text-xs font-bold text-teal-600 tracking-widest uppercase">02</span>
        <h3 class="mt-3 text-xl font-bold text-gray-900 leading-snug">Schedules shift. Patients get told.</h3>
        <p class="mt-2 text-sm text-gray-400 leading-relaxed">A procedure runs long. An emergency comes in. The moment timing changes, patients get a text — before they leave home, not after they've been sitting for 40 minutes.</p>
      </div>
      <div class="reveal reveal-delay-2">
        <span class="text-xs font-bold text-teal-600 tracking-widest uppercase">03</span>
        <h3 class="mt-3 text-xl font-bold text-gray-900 leading-snug">Nobody wastes time</h3>
        <p class="mt-2 text-sm text-gray-400 leading-relaxed">The mom with two kids in the car knows to wait 15 more minutes. The elderly patient driving an hour knows to leave later. The doctor knows their patients aren't angry. Everyone wins.</p>
      </div>
    </div>
  </div>
</section>

<!-- ====== GLOW DIVIDER ====== -->
<div class="glow-line mx-auto max-w-xl"></div>

<!-- ====== QUOTE ====== -->
<section class="py-28 px-6 reveal">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-3xl sm:text-[2.5rem] font-extrabold text-gray-900 leading-[1.15] tracking-[-0.02em]">
      Health is not a joke.<br>
      <span class="text-gray-300">People's time isn't either.</span>
    </p>
  </div>
</section>

<!-- ====== FEATURES ====== -->
<section class="py-20 px-6 bg-gray-50/80">
  <div class="mx-auto max-w-4xl space-y-6">
    <% [
      { title: "Proactive text updates — before they ask", desc: "The moment a provider's schedule shifts, every affected patient gets a text. Not after they've been sitting for 30 minutes — before they leave home. A mom with three kids can plan. An elderly patient driving an hour can adjust." },
      { title: "Every provider's calendar, one view", desc: "Pediatrics uses Epic. The therapist uses Google Calendar. The new NP uses Calendly. Schedulite syncs them all and coordinates patient communication across every provider, every specialty." },
      { title: "Self-check-in that frees your front desk", desc: "Tablet in the lobby. Patient enters their phone number. They're checked in, the provider is notified, and the patient gets a live status link — all in one tap." },
      { title: "Staff scheduling and time clock", desc: "Shifts, clock in/out, timesheets, time-off requests. Your whole team coordinated in one place — not just appointments." },
      { title: "No-show fees that are actually fair", desc: "Store cards securely via Stripe. If someone no-shows, charge the fee automatically — or waive it with one click. Patients are told the policy upfront." },
      { title: "When we make you wait, we make it right", desc: "Set a delay threshold — say 20 minutes. If a patient waits longer, Schedulite automatically sends them a gift card to a nearby coffee shop or small business as a goodwill gesture. It turns a bad wait into a memorable experience. No other scheduling tool does this." }
    ].each_with_index do |f, i| %>
      <div class="reveal rounded-2xl bg-white border border-gray-200/80 px-7 py-5 flex items-start gap-5 hover:border-teal-200 transition-colors duration-300">
        <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center shrink-0 mt-0.5">
          <span class="text-xs font-bold text-teal-600"><%= i + 1 %></span>
        </div>
        <div>
          <h3 class="text-[15px] font-semibold text-gray-900"><%= f[:title] %></h3>
          <p class="mt-1 text-sm text-gray-400 leading-relaxed"><%= f[:desc] %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- ====== CTA ====== -->
<section class="py-32 px-6 reveal">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-[-0.02em]">Free to start.<br>Takes five minutes.</h2>
    <p class="mt-4 text-gray-400">No credit card. No sales call. No onboarding meeting.<br>Just sign up and connect your calendar.</p>
    <div class="mt-10">
      <%= link_to register_path, class: "inline-block rounded-full bg-teal-600 px-8 py-4 text-base font-semibold text-white hover:bg-teal-500 transition cta-glow" do %>
        Create Your Practice
      <% end %>
    </div>
  </div>
</section>

