<!-- ============================================ -->
<section id="faq" class="py-24 px-6 bg-gray-50">
  <div class="mx-auto max-w-3xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-gray-900">Frequently asked questions</h2>
    </div>

    <div class="space-y-4">
      <% [
        ["How long does setup take?", "Under 5 minutes. Create your account, add your first provider, connect your calendar, and you're live. No IT department needed."],
        ["Do patients need to download an app?", "No. Everything happens via SMS text messages and a web-based status page. Patients just need a phone that receives texts."],
        ["Is Schedulite HIPAA compliant?", "Schedulite is HIPAA-ready. All patient data is encrypted at rest and in transit. SMS messages never contain diagnosis, insurance, or clinical information — only first names, appointment times, and status updates. We offer a BAA on our Pro and Enterprise plans."],
        ["What calendars and EHR systems do you integrate with?", "Google Calendar, Microsoft Outlook, Apple Calendar, Calendly, Cal.com, Acuity, and any iCal feed. For EHR systems: Epic, Athena, Cerner, DrChrono, and more via FHIR R4. Plus Jane App, SimplePractice, NexHealth, and Open Dental."],
        ["Can I charge no-show fees?", "Yes. Securely store patient credit cards via Stripe (PCI compliant). Set your fee amount, and it's automatically charged when a patient is marked as a no-show. Staff can also waive charges with one click."],
        ["What happens after the free trial?", "Your account continues on the Free plan (5 appointments/day, 1 provider). No data is lost. Upgrade to Pro anytime for unlimited usage."]
      ].each do |question, answer| %>
        <details class="group rounded-2xl bg-white border border-gray-200 overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
            <span class="text-sm font-semibold text-gray-900"><%= question %></span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-gray-400 shrink-0 transition group-open:rotate-180"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-4 text-sm text-gray-600 leading-relaxed"><%= answer %></div>
        </details>
      <% end %>
    </div>
  </div>
</section>

