          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-red-400 shrink-0 mt-0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-sm text-gray-600 leading-relaxed"><%= pain %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Solution -->
    <div>
      <span class="text-xs font-bold text-teal-600 uppercase tracking-widest">The solution</span>
      <h2 class="mt-3 text-3xl font-bold text-gray-900 leading-tight">One platform that keeps everyone in sync</h2>
      <div class="mt-6 space-y-4">
        <% ["Patients get real-time SMS — they know exactly where they stand", "Self-check-in kiosk frees your front desk completely", "Auto-charge no-show fees with cards on file", "One calendar sync covers Google, Outlook, Apple, Epic, Athena, and 10 more"].each do |solution| %>
