<nav class="fixed top-0 inset-x-0 z-50 bg-white/90 backdrop-blur-md">
  <div class="mx-auto max-w-5xl px-6 py-4 flex items-center justify-between">
    <span class="text-xl font-bold text-teal-600 tracking-tight">Schedulite</span>
    <div class="flex items-center gap-3">
      <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-500 hover:text-gray-900 transition px-3 py-2" %>
      <%= link_to "Try It Free", register_path, class: "rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-500 transition" %>
    </div>
  </div>
</nav>

<!-- Hero -->
<section class="pt-32 pb-16 px-6">
  <div class="mx-auto max-w-3xl text-center">
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-[1.1]">
      Your patients are waiting.<br>They shouldn't have to wonder for how long.
    </h1>
    <p class="mt-6 text-lg text-gray-500 max-w-xl mx-auto">
      Schedulite sends real-time text updates so patients always know where they stand. No app. No portal. Just a text.
    </p>
    <div class="mt-8">
      <%= link_to register_path, class: "inline-block rounded-2xl bg-teal-600 px-8 py-4 text-base font-semibold text-white hover:bg-teal-500 transition shadow-lg shadow-teal-600/20" do %>
        Start Free — No Credit Card
      <% end %>
    </div>
  </div>
</section>

<!-- What it does -->
<section class="py-16 px-6">
  <div class="mx-auto max-w-4xl grid grid-cols-1 sm:grid-cols-3 gap-8">
    <div>
      <div class="w-9 h-9 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
      </div>
      <h3 class="font-semibold text-gray-900">Text updates, not apps</h3>
      <p class="mt-1 text-sm text-gray-500">Patients get checked-in, delay, and "you're next" texts automatically. Works on every phone.</p>
    </div>
    <div>
      <div class="w-9 h-9 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
      </div>
      <h3 class="font-semibold text-gray-900">Syncs with your calendar</h3>
      <p class="mt-1 text-sm text-gray-500">Google, Outlook, Apple, Epic, Athena, Calendly — whatever your team uses. One sync.</p>
    </div>
    <div>
      <div class="w-9 h-9 rounded-lg bg-teal-50 flex items-center justify-center mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
      </div>
      <h3 class="font-semibold text-gray-900">Tablet check-in</h3>
      <p class="mt-1 text-sm text-gray-500">Patients type their phone number on a tablet in the lobby. No clipboard. No line.</p>
    </div>
  </div>
</section>

<!-- One-liner -->
<section class="py-16 px-6 bg-gray-900">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-2xl sm:text-3xl font-bold text-white leading-snug">
      People don't mind waiting.<br>
      <span class="text-teal-400">They mind not being told.</span>
    </p>
  </div>
</section>

<!-- CTA -->
<section class="py-20 px-6">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-2xl font-bold text-gray-900">Free to start. Takes 5 minutes.</h2>
    <p class="mt-3 text-gray-500">No credit card. No sales call. Just sign up and connect your calendar.</p>
    <div class="mt-8">
      <%= link_to register_path, class: "inline-block rounded-2xl bg-teal-600 px-8 py-4 text-base font-semibold text-white hover:bg-teal-500 transition shadow-lg shadow-teal-600/20" do %>
        Create Your Practice
      <% end %>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 border-t border-gray-100">
  <div class="mx-auto max-w-5xl flex items-center justify-between text-xs text-gray-400">
    <span>&copy; <%= Date.current.year %> Schedulite</span>
    <div class="flex gap-4">
      <%= link_to "Sign In", new_user_session_path, class: "hover:text-gray-600" %>
      <a href="mailto:hello@schedulite.com" class="hover:text-gray-600">Contact</a>
    </div>
  </div>
</footer>
