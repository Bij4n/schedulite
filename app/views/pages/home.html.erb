        <div class="flex justify-start"><div class="rounded-2xl rounded-bl-sm bg-white border border-gray-200 px-4 py-2.5 text-sm max-w-xs text-gray-700">Ok thanks!</div></div>
        <div class="flex justify-end"><div class="rounded-2xl rounded-br-sm bg-teal-600 text-white px-4 py-2.5 text-sm max-w-xs">You're next! Please head to the front desk.</div></div>
      </div>
    </div>

    <!-- Feature 2: Kiosk -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1 rounded-3xl bg-gray-900 p-10 text-center">
        <div class="text-4xl font-bold text-white mb-3">Check In</div>
