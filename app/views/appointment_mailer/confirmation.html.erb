<h2>Your appointment is confirmed</h2>

<p>Hi <%= @patient.first_name %>,</p>

<p>Your appointment has been scheduled:</p>

<table style="margin: 16px 0; border-collapse: collapse;">
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">Date</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @appointment.starts_at.strftime("%A, %B %-d, %Y") %></td>
  </tr>
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">Time</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @appointment.starts_at.strftime("%-l:%M %p") %></td>
  </tr>
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">Provider</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @provider.display_name %></td>
  </tr>
  <tr>
    <td style="padding: 4px 12px 4px 0; color: #6b7280; font-size: 14px;">Practice</td>
    <td style="padding: 4px 0; font-weight: 600;"><%= @tenant.name %></td>
  </tr>
</table>

<p style="font-size: 14px; color: #6b7280;">A calendar invitation is attached to this email.</p>

<p style="font-size: 12px; color: #9ca3af; margin-top: 24px;">— <%= @tenant.name %> via Schedulite</p>
