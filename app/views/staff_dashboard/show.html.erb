<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-3xl px-4 py-5 sm:px-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Check-In Queue</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= Date.current.strftime("%A, %B %-d") %> · <%= @appointments.size %> appointments</p>
        </div>

        <!-- Clock in/out -->
        <% if @clocked_in %>
          <%= link_to clock_out_time_clock_index_path, data: { turbo_method: :post },
            class: "flex items-center gap-2 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 px-4 py-2.5 text-sm font-medium text-red-700 dark:text-red-300 hover:bg-red-100 transition" do %>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span>
            Clock Out
          <% end %>
        <% else %>
          <%= link_to clock_in_time_clock_index_path, data: { turbo_method: :post },
            class: "flex items-center gap-2 rounded-2xl bg-teal-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-teal-500 transition" do %>
            Clock In
          <% end %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-6 sm:px-6">
    <% if @appointments.any? %>
      <div class="space-y-3">
        <% @appointments.each do |appointment| %>
          <%= render AppointmentRowComponent.new(appointment: appointment) %>
        <% end %>
      </div>
    <% else %>
      <%= render EmptyStateComponent.new(title: "No appointments today", description: "The schedule is clear.") %>
    <% end %>
  </main>
</div>
