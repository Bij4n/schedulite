<div class="min-h-screen flex items-center justify-center px-6 py-12 bg-gray-50">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Sign in</h1>
      <p class="mt-2 text-sm text-gray-500">We'll text you a sign-in link.</p>
    </div>

    <% if flash[:notice] %>
      <div class="mb-4 rounded-xl bg-teal-50 border border-teal-200 p-4 text-sm text-teal-700"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with(url: portal_request_link_path, class: "space-y-5 rounded-2xl bg-white border border-gray-200 p-8 shadow-sm") do %>
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700">Phone number</label>
        <%= telephone_field_tag :phone, nil, required: true, placeholder: "(555) 123-4567",
          class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
      </div>
      <%= submit_tag "Send Sign-In Link",
        class: "flex w-full justify-center rounded-xl bg-teal-600 px-4 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer transition" %>
    <% end %>
  </div>
</div>
