<%= form_with(model: @location, class: "space-y-4 rounded-2xl bg-white border border-gray-200 p-8 shadow-sm") do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, required: true,
      class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>
  <div>
    <%= f.label :address, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :address,
      class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>
  <div class="grid grid-cols-3 gap-3">
    <div>
      <%= f.label :city, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :city, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <%= f.label :state, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :state, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <%= f.label :zip, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :zip, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
  </div>
  <%= f.submit class: "flex w-full justify-center rounded-xl bg-teal-600 px-4 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer transition" %>
<% end %>
