<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title>Check In - Schedulite</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
</head>
<body class="h-full bg-gray-50 dark:bg-gray-900 font-sans text-gray-900 dark:text-gray-100 antialiased">
  <% if alert.present? %>
    <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 rounded-2xl bg-red-50 dark:bg-red-900/20 px-5 py-3 text-sm text-red-800 dark:text-red-300 shadow-md max-w-sm text-center">
      <%= alert %>
    </div>
  <% end %>
  <%= yield %>
</body>
</html>
