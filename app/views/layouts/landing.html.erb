<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
<head>
  <title>Schedulite — Real-Time Appointment Check-In for Medical Practices</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Real-time SMS updates so patients always know where they stand. No app. No portal. Just a text.">
  <%= csrf_meta_tags %>
  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <style>
    :root { --teal: #0E9C8A; }

    /* Gradient text */
    .grad { background: linear-gradient(135deg, #5eead4 0%, #0E9C8A 40%, #0f766e 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* Ambient glow behind hero */
    .hero-glow {
      position: absolute; top: -30%; left: 50%; transform: translateX(-50%);
      width: 140%; height: 600px;
      background: radial-gradient(ellipse at center, rgba(14,156,138,0.10) 0%, rgba(14,156,138,0.04) 40%, transparent 70%);
      pointer-events: none; z-index: 0;
    }

    /* CTA glow */
    .cta-glow { box-shadow: 0 4px 40px rgba(14,156,138,0.35); transition: box-shadow 0.3s; }
    .cta-glow:hover { box-shadow: 0 4px 60px rgba(14,156,138,0.5); }

    /* Scroll reveal */
    .reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* SMS bubble animation */
    .sms-bubble { opacity: 0; transform: translateY(12px); animation: bubbleIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
    .sms-bubble:nth-child(1) { animation-delay: 0.6s; }
    .sms-bubble:nth-child(2) { animation-delay: 1.4s; }
    .sms-bubble:nth-child(3) { animation-delay: 2.2s; }
    .sms-bubble:nth-child(4) { animation-delay: 3.0s; }
    @keyframes bubbleIn { to { opacity: 1; transform: translateY(0); } }

    /* Subtle float */
    @keyframes drift { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    .drift { animation: drift 5s ease-in-out infinite; }

    /* Divider glow */
    .glow-line { height: 1px; background: linear-gradient(90deg, transparent 0%, rgba(14,156,138,0.3) 50%, transparent 100%); }
  </style>
</head>
<body class="h-full bg-white font-sans text-gray-900 antialiased overflow-x-hidden">
  <%= yield %>

  <script>
    // Scroll reveal observer
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>
</body>
</html>
