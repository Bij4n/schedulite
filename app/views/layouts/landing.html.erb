<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
<head>
  <title>Schedulite — Real-Time Appointment Check-In for Medical Practices</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Real-time SMS updates so patients always know where they stand. No app. No portal. Just a text.">
  <%= csrf_meta_tags %>
  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <style>
    :root { --teal: #0E9C8A; }

    /* Gradient text */
    .grad { background: linear-gradient(135deg, #5eead4 0%, #0E9C8A 40%, #0f766e 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* Ambient glow behind hero */
    .hero-glow {
      position: absolute; top: -30%; left: 50%; transform: translateX(-50%);
      width: 140%; height: 600px;
      background: radial-gradient(ellipse at center, rgba(14,156,138,0.10) 0%, rgba(14,156,138,0.04) 40%, transparent 70%);
      pointer-events: none; z-index: 0;
    }

    /* CTA glow */
    .cta-glow { box-shadow: 0 4px 40px rgba(14,156,138,0.35); transition: box-shadow 0.3s; }
    .cta-glow:hover { box-shadow: 0 4px 60px rgba(14,156,138,0.5); }

    /* Scroll reveal */
    .reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ====== Feature card animations ====== */
    .feature-card {
      opacity: 0;
      transform: translateY(40px) scale(0.98);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1), border-color 0.4s ease, box-shadow 0.4s ease;
      position: relative;
      overflow: hidden;
    }
    .feature-card.visible { opacity: 1; transform: translateY(0) scale(1); }
    /* Stagger entry by index — set via inline style */
    .feature-card:hover { border-color: rgba(94, 234, 212, 0.6); box-shadow: 0 12px 32px -12px rgba(14, 156, 138, 0.18); transform: translateY(-2px); }

    /* Animated number badge */
    .feature-num {
      position: relative;
      background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%);
      transition: transform 0.5s cubic-bezier(0.16,1,0.3,1) 0.2s, background 0.4s ease;
    }
    .feature-card.visible .feature-num {
      transform: scale(1);
      animation: numPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }
    @keyframes numPop {
      0% { transform: scale(0.4) rotate(-10deg); }
      60% { transform: scale(1.15) rotate(2deg); }
      100% { transform: scale(1) rotate(0deg); }
    }
    .feature-card:hover .feature-num {
      background: linear-gradient(135deg, #0E9C8A 0%, #0f766e 100%);
    }
    .feature-card:hover .feature-num span { color: #ffffff; }
    .feature-num span { transition: color 0.3s ease; }

    /* Sweeping shimmer on intersection */
    .feature-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 30%, rgba(94, 234, 212, 0.10) 50%, transparent 70%);
      transform: translateX(-100%);
      pointer-events: none;
    }
    .feature-card.visible::before {
      animation: shimmer 1.4s ease-out 0.4s 1;
    }
    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    /* Mobile-first tweaks */
    @media (max-width: 640px) {
      .feature-card { transform: translateY(24px) scale(1); }
      .feature-card:hover { transform: none; box-shadow: none; }
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .reveal, .feature-card { opacity: 1; transform: none; transition: none; }
      .feature-card.visible .feature-num { animation: none; }
      .feature-card.visible::before { animation: none; }
      .drift { animation: none; }
      .sms-bubble { opacity: 1; transform: none; animation: none; }
    }

    /* SMS bubble animation */
    .sms-bubble { opacity: 0; transform: translateY(12px); animation: bubbleIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
    .sms-bubble:nth-child(1) { animation-delay: 0.6s; }
    .sms-bubble:nth-child(2) { animation-delay: 1.4s; }
    .sms-bubble:nth-child(3) { animation-delay: 2.2s; }
    .sms-bubble:nth-child(4) { animation-delay: 3.0s; }
    @keyframes bubbleIn { to { opacity: 1; transform: translateY(0); } }

    /* Subtle float */
    @keyframes drift { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    .drift { animation: drift 5s ease-in-out infinite; }

    /* Divider glow */
    .glow-line { height: 1px; background: linear-gradient(90deg, transparent 0%, rgba(14,156,138,0.3) 50%, transparent 100%); }
  </style>
</head>
<body class="h-full bg-white font-sans text-gray-900 antialiased overflow-x-hidden">
  <%= yield %>

  <script>
    // Scroll reveal observer
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // Feature card observer — staggered, lower threshold for mobile
    const featureObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); featureObs.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.feature-card').forEach(el => featureObs.observe(el));
  </script>
</body>
</html>
