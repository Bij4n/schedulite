<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100">Appointment Detail</h1>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-4 py-6 sm:px-6 space-y-6">
    <!-- Patient info -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @appointment.patient.display_name %></h2>
          <p class="text-sm text-gray-500 dark:text-gray-400"><%= @appointment.provider.display_name %></p>
        </div>
        <%= render StatusPillComponent.new(status: @appointment.status) %>
      </div>
      <div class="mt-4 flex items-center justify-between">
        <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span><%= @appointment.starts_at.strftime("%A, %B %-d · %-l:%M %p") %></span>
          <span class="text-gray-300 dark:text-gray-600">·</span>
          <span><%= @appointment.duration_minutes || 30 %> min</span>
          <% if @appointment.delay_minutes.to_i > 0 %>
            <span class="text-amber-600 dark:text-amber-400 font-medium">+<%= @appointment.delay_minutes %> min delay</span>
          <% end %>
        </div>
        <%= link_to calendar_appointment_path(@appointment), class: "flex items-center gap-1.5 rounded-lg bg-gray-100 dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          Add to Calendar
        <% end %>
      </div>
    </div>

    <!-- Actions -->
    <% unless @appointment.complete? || @appointment.canceled? || @appointment.no_show? %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Running Late?</h3>
        <%= render DelayButtonComponent.new(appointment: @appointment) %>
      </div>

      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Manage Appointment</h3>
        <div class="flex gap-3">
          <%= link_to "Reschedule", edit_appointment_path(@appointment),
            class: "flex-1 rounded-xl bg-gray-100 dark:bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition text-center" %>
          <%= link_to "Cancel Appointment", cancel_appointment_path(@appointment),
            data: { turbo_method: :patch, turbo_confirm: "Cancel this appointment? The patient will be notified." },
            class: "flex-1 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 px-4 py-2.5 text-sm font-medium text-red-700 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 transition text-center" %>
        </div>
      </div>
    <% end %>

    <!-- SMS conversation link -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">SMS Messages</h3>
        <%= link_to "View Conversation", appointment_conversation_path(@appointment), class: "text-sm text-teal-600 hover:text-teal-500" %>
      </div>
    </div>

    <!-- Status history -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Status History</h3>
      <% if @appointment.status_events.any? %>
        <div class="space-y-3">
          <% @appointment.status_events.order(created_at: :desc).each do |event| %>
            <div class="flex items-center justify-between text-sm">
              <div class="flex items-center gap-2">
                <%= render StatusPillComponent.new(status: event.to_status) %>
                <% if event.delay_minutes %>
                  <span class="text-amber-600 dark:text-amber-400 text-xs">+<%= event.delay_minutes %> min</span>
                <% end %>
              </div>
              <span class="text-xs text-gray-400"><%= event.created_at.strftime("%-l:%M %p") %></span>
            </div>
            <% if event.note.present? %>
              <p class="text-xs text-gray-500 dark:text-gray-400 ml-2"><%= event.note %></p>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">No status changes yet</p>
      <% end %>
    </div>
  </main>
</div>
