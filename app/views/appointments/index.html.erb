<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Appointments</h1>
        <%= link_to "New Appointment", new_appointment_path, class: "rounded-xl bg-teal-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-teal-500" %>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-4 py-6 sm:px-6 space-y-3">
    <% if @appointments.any? %>
      <% @appointments.group_by { |a| a.starts_at.to_date }.each do |date, appts| %>
        <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide pt-2"><%= date.strftime("%A, %B %-d") %></h3>
        <% appts.each do |appointment| %>
          <%= render AppointmentRowComponent.new(appointment: appointment) %>
        <% end %>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(title: "No appointments", description: "Create your first appointment to get started.") %>
    <% end %>
  </main>
</div>
