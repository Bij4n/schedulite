<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-lg px-4 py-4 sm:max-w-2xl sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to appointment_path(@appointment), class: "text-gray-400 hover:text-gray-600", aria: { label: "Back" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        <% end %>
        <div>
          <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100"><%= @appointment.patient.display_name %></h1>
          <p class="text-xs text-gray-500 dark:text-gray-400">SMS Conversation</p>
        </div>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-lg px-4 py-6 sm:max-w-2xl sm:px-6">
    <div class="space-y-3">
      <% if @messages.empty? %>
        <%= render EmptyStateComponent.new(title: "No messages yet", description: "SMS messages will appear here when sent or received.") %>
      <% else %>
        <% @messages.each do |msg| %>
          <div class="flex <%= msg.outbound? ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-[80%] rounded-2xl px-4 py-2 text-sm <%= msg.outbound? ? 'bg-teal-600 text-white' : 'bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 ring-1 ring-gray-900/5 dark:ring-gray-700' %>">
              <p><%= msg.body %></p>
              <p class="mt-1 text-xs <%= msg.outbound? ? 'text-teal-200' : 'text-gray-400' %>">
                <%= msg.created_at.strftime("%-l:%M %p") %>
              </p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </main>
</div>
