<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to appointment_path(@appointment), class: "text-gray-400 hover:text-gray-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100">Reschedule Appointment</h1>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-lg px-4 py-6 sm:px-6">
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700 mb-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Patient: <span class="font-medium text-gray-900 dark:text-gray-100"><%= @appointment.patient.display_name %></span>
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Current time: <span class="font-medium text-gray-900 dark:text-gray-100"><%= @appointment.starts_at.strftime("%A, %B %-d · %-l:%M %p") %></span>
      </p>
    </div>

    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
      <%= form_with(model: @appointment, class: "space-y-4") do |f| %>
        <% if @appointment.errors.any? %>
          <div class="rounded-xl bg-red-50 dark:bg-red-900/20 p-4 text-sm text-red-700 dark:text-red-400" role="alert">
            <% @appointment.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :provider_id, "Provider", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.select :provider_id,
                @providers.map { |p| [p.display_name, p.id] },
                {},
                class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
        </div>

        <div>
          <%= f.label :starts_at, "New Date & Time", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.datetime_local_field :starts_at, required: true, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
        </div>

        <div>
          <%= f.label :duration_minutes, "Duration", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.select :duration_minutes,
                [["15 minutes", 15], ["30 minutes", 30], ["45 minutes", 45], ["60 minutes", 60], ["90 minutes", 90]],
                {},
                class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
        </div>

        <div>
          <%= f.label :notes, "Notes (optional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.text_area :notes, rows: 2, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
        </div>

        <%= f.submit "Reschedule Appointment", class: "w-full rounded-xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
      <% end %>
    </div>
  </main>
</div>
