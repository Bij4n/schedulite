<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <%= link_to settings_staff_index_path, class: "text-gray-400 hover:text-gray-600" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
          <% end %>
          <div>
            <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100"><%= @staff_member.full_name %></h1>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= @staff_member.role.humanize %> · <%= @weekly_hours %> hrs/week</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-4 py-6 sm:px-6 space-y-6">
    <!-- Weekly schedule grid -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">Weekly Schedule</h3>

      <% if @shifts.any? %>
        <div class="space-y-2">
          <% @shifts.each do |shift| %>
            <div class="flex items-center justify-between py-2.5 px-3 -mx-3 rounded-xl <%= shift.active? ? 'bg-green-50/50 dark:bg-green-900/10' : shift.proposed? ? 'bg-amber-50/50 dark:bg-amber-900/10' : '' %>">
              <div class="flex items-center gap-4">
                <span class="font-medium text-gray-900 dark:text-gray-100 w-24 text-sm"><%= shift.day_name %></span>
                <span class="text-sm text-gray-600 dark:text-gray-300"><%= shift.start_time %> – <%= shift.end_time %></span>
                <span class="text-xs text-gray-400">(<%= shift.break_minutes %> min break)</span>
                <span class="text-xs text-gray-400"><%= shift.hours %> hrs</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium rounded-full px-2 py-0.5 <%= shift.active? ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300' : shift.proposed? ? 'bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-500' %>">
                  <%= shift.status.capitalize %>
                </span>
                <% if shift.proposed? %>
                  <%= link_to "Approve", approve_settings_staff_shift_path(@staff_member, shift),
                    data: { turbo_method: :patch }, class: "text-xs text-teal-600 hover:text-teal-500" %>
                <% end %>
                <%= link_to settings_staff_shift_path(@staff_member, shift),
                  data: { turbo_method: :delete, turbo_confirm: "Remove this shift?" },
                  class: "text-xs text-gray-400 hover:text-red-500" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 text-center py-4">No shifts scheduled</p>
      <% end %>
    </div>

    <!-- Add shift form -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Add Shift</h3>

      <%= form_with(model: StaffShift.new, url: settings_staff_shifts_path(@staff_member), class: "space-y-3") do |f| %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :day_of_week, "Day", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.select :day_of_week, StaffShift::DAY_NAMES.each_with_index.map { |name, i| [name, i] },
              {}, class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
          </div>
          <div>
            <%= f.label :break_minutes, "Break", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.select :break_minutes, [["15 min", 15], ["30 min", 30], ["45 min", 45], ["60 min", 60]],
              { selected: current_user.tenant.default_break_minutes || 30 },
              class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :start_time, "Start", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.time_field :start_time, value: current_user.tenant.default_shift_start || "09:00",
              class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
          </div>
          <div>
            <%= f.label :end_time, "End", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.time_field :end_time, value: current_user.tenant.default_shift_end || "17:00",
              class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
          </div>
        </div>
        <%= f.submit "Add Shift", class: "w-full rounded-xl bg-teal-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
      <% end %>
    </div>
  </main>
</div>
