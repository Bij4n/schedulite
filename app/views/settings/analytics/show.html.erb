<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Settings</h1>
        <%= link_to "Export CSV", export_settings_analytics_path(format: :csv), class: "text-xs text-teal-600 hover:text-teal-500" %>
      </div>
    </div>
  </header>

  <%= render "settings/nav" %>

  <main class="mx-auto max-w-2xl px-4 py-4 sm:px-6 space-y-4">
    <!-- Summary cards -->
    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-4 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700 text-center">
        <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @summary[:total] %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Today's Appointments</p>
      </div>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-4 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700 text-center">
        <p class="text-2xl font-bold text-teal-600"><%= @summary[:complete] %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Completed</p>
      </div>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-4 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700 text-center">
        <p class="text-2xl font-bold text-amber-600"><%= @avg_wait %> min</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Avg Wait (30d)</p>
      </div>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-4 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700 text-center">
        <p class="text-2xl font-bold text-gray-600 dark:text-gray-300"><%= @no_show_rate %>%</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">No-Show Rate (30d)</p>
      </div>
    </div>

    <!-- Status breakdown -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Today's Status Breakdown</h3>
      <div class="space-y-2">
        <% %w[checked_in in_room running_late scheduled no_show canceled].each do |status| %>
          <% count = @summary[status.to_sym] %>
          <% next if count.zero? %>
          <div class="flex items-center justify-between">
            <%= render StatusPillComponent.new(status: status) %>
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= count %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Provider utilization -->
    <% if @utilization.any? %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Provider Utilization (30d)</h3>
        <div class="space-y-2">
          <% @utilization.each do |entry| %>
            <% prov = Provider.find_by(id: entry[:provider_id]) %>
            <% next unless prov %>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= prov.display_name %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= entry[:count] %> appts</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </main>
</div>
