<div class="min-h-screen bg-gray-50">
  <header class="sticky top-0 z-10 bg-white/80 backdrop-blur-sm border-b border-gray-100">
    <div class="mx-auto max-w-lg px-4 py-4 sm:max-w-2xl sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900">Integrations</h1>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-lg px-4 py-6 sm:max-w-2xl sm:px-6 space-y-4">
    <% if @integrations.any? %>
      <% @integrations.each do |integration| %>
        <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-sm font-semibold text-gray-900 capitalize"><%= integration.adapter_type %></h3>
              <p class="text-xs text-gray-500">
                Status: <span class="font-medium <%= integration.status == 'active' ? 'text-teal-600' : 'text-gray-400' %>"><%= integration.status %></span>
                <% if integration.last_synced_at %>
                  &middot; Last synced <%= time_ago_in_words(integration.last_synced_at) %> ago
                <% end %>
              </p>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to "Disconnect",
                settings_integration_path(integration),
                data: { turbo_method: :delete, turbo_confirm: "Disconnect this integration?" },
                class: "text-xs text-red-600 hover:text-red-500" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(
        title: "No integrations connected",
        description: "Connect your EHR, booking system, or calendar to sync appointments automatically."
      ) %>
    <% end %>
  </main>
</div>
