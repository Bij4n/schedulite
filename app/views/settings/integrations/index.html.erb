<%= render layout: "settings/layout" do %>
  <div class="space-y-8">
    <!-- Connected integrations with inline health -->
    <% if @integrations.any? %>
      <section>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Connected</h2>
        <div class="space-y-3">
          <% @integrations.each do |integration| %>
            <% display_name = @available.find { |a| a[:type] == integration.adapter_type }&.dig(:name) || integration.adapter_type.humanize %>
            <div class="rounded-2xl bg-white dark:bg-gray-800 p-4 border border-gray-200 dark:border-gray-700">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-2.5 h-2.5 rounded-full shrink-0 <%= integration.sync_status == :healthy ? 'bg-green-500' : integration.sync_status == :stale ? 'bg-amber-500' : 'bg-red-500 animate-pulse' %>"></div>
                  <div>
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= display_name %></h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                      <% if integration.provider %><%= integration.provider.display_name %> · <% end %>
                      <% if integration.last_synced_at %>Synced <%= time_ago_in_words(integration.last_synced_at) %> ago<% else %>Never synced<% end %>
                    </p>
                  </div>
                </div>
                <%= link_to "Disconnect", settings_integration_path(integration),
                  data: { turbo_method: :delete, turbo_confirm: "Disconnect?" },
                  class: "text-xs text-red-500 hover:text-red-400" %>
              </div>
              <% if integration.sync_error.present? %>
                <p class="mt-2 text-xs text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/10 rounded-lg p-2"><%= integration.sync_error.truncate(120) %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <!-- EHR Systems -->
    <% ehr = @available.select { |a| a[:category] == "ehr" } %>
    <section>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">EHR Systems</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Connect your electronic health records to sync appointments automatically.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% ehr.each do |avail| %>
          <%= render_integration_card(avail, recommended: true) %>
        <% end %>
      </div>
    </section>

    <!-- Calendars & Scheduling -->
    <% calendars = @available.select { |a| a[:category] == "calendar" } %>
    <section>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Calendars & Scheduling</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Sync from popular calendar and scheduling tools. Each provider can connect their own.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% calendars.each do |avail| %>
          <%= render_integration_card(avail, recommended: %w[google_calendar outlook apple_calendar].include?(avail[:type])) %>
        <% end %>
      </div>
    </section>

    <!-- Practice Management -->
    <% pms = @available.select { |a| a[:category] == "pms" } %>
    <section>
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Practice Management</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Connect specialty practice management and billing systems.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% pms.each do |avail| %>
          <%= render_integration_card(avail) %>
        <% end %>
      </div>
    </section>
  </div>
<% end %>
