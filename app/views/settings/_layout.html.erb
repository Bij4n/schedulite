<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Settings</h1>
    </div>
  </header>

  <!-- Mobile nav -->
  <div class="sm:hidden">
    <%= render SettingsNavComponent.new(current_path: request.path, current_user: current_user) %>
  </div>

  <div class="mx-auto max-w-5xl px-4 py-6 sm:px-6">
    <div class="sm:flex sm:gap-8">
      <!-- Desktop sidebar -->
      <div class="hidden sm:block sm:w-44 sm:shrink-0">
        <%= render SettingsNavComponent.new(current_path: request.path, current_user: current_user) %>
      </div>

      <!-- Content -->
      <div class="flex-1 min-w-0">
        <%= yield %>
      </div>
    </div>
  </div>
</div>
