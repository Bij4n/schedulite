<%= render layout: "settings/layout" do %>
  <div class="space-y-6">
    <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">New Workflow Template</h2>

    <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
      <%= form_with(model: @template, url: settings_workflow_templates_path, class: "space-y-4") do |f| %>
        <div>
          <%= f.label :name, "Template Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.text_field :name, placeholder: "Provider Running Late", required: true,
            class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
        </div>

        <div>
          <%= f.label :message_body, "Message Template", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= f.text_area :message_body, rows: 4, required: true,
            class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
          <p class="mt-1 text-xs text-gray-400">Variables: %{provider_name}, %{delay_minutes}, %{original_time}, %{new_time}</p>
        </div>

        <div class="space-y-3">
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Patient Options</p>
          <div class="flex items-center gap-3">
            <%= f.check_box :offer_reschedule, class: "h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-teal-600 focus:ring-teal-600" %>
            <%= f.label :offer_reschedule, "Offer to reschedule", class: "text-sm text-gray-600 dark:text-gray-400" %>
          </div>
          <div class="flex items-center gap-3">
            <%= f.check_box :offer_cancel, class: "h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-teal-600 focus:ring-teal-600" %>
            <%= f.label :offer_cancel, "Offer to cancel", class: "text-sm text-gray-600 dark:text-gray-400" %>
          </div>
          <div class="flex items-center gap-3">
            <%= f.check_box :offer_gift_card, class: "h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-teal-600 focus:ring-teal-600" %>
            <%= f.label :offer_gift_card, "Offer gift card for waiting", class: "text-sm text-gray-600 dark:text-gray-400" %>
          </div>
        </div>

        <%= f.submit "Create Template", class: "w-full rounded-xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
      <% end %>
    </div>
  </div>
<% end %>
