<%= turbo_stream_from "appointment_status_#{@appointment.signed_token}" %>

<div class="min-h-screen flex items-start justify-center px-4 pt-12 pb-8">
  <div class="w-full max-w-sm space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Schedulite</h1>
    </div>

    <div id="status_card" class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700 space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400">Your appointment</p>
          <p class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @appointment.starts_at.strftime("%-l:%M %p") %></p>
        </div>
        <%= render StatusPillComponent.new(status: @appointment.status) %>
      </div>

      <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
        <p class="text-sm text-gray-900 dark:text-gray-100">
          Hi <strong><%= @appointment.patient.first_name %></strong>, you're
          <% case @appointment.status %>
          <% when "scheduled" %>
            scheduled for your appointment with <strong><%= @appointment.provider.display_name %></strong>.
          <% when "checked_in" %>
            checked in for your appointment with <strong><%= @appointment.provider.display_name %></strong>.
          <% when "in_room" %>
            in the room. <strong><%= @appointment.provider.display_name %></strong> will be with you shortly.
          <% when "running_late" %>
            checked in. <strong><%= @appointment.provider.display_name %></strong> is running about
            <strong><%= @appointment.delay_minutes || "a few" %> minutes</strong> behind.
            We'll text you when you're up next.
          <% when "complete" %>
            all done! Thank you for your visit.
          <% when "no_show", "canceled" %>
            not currently scheduled. Please contact the office with questions.
          <% end %>
        </p>
      </div>

      <% unless @appointment.complete? || @appointment.canceled? %>
        <%= link_to calendar_appointment_path(@appointment), class: "flex items-center justify-center gap-2 rounded-xl bg-gray-100 dark:bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          Add to Google / Apple Calendar
        <% end %>
      <% end %>

      <% if @appointment.delay_minutes.to_i > 0 && !@appointment.complete? %>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-800 dark:text-amber-300">
          Current wait: ~<%= @appointment.delay_minutes %> min. We'll text you 10 min before you're up.
        </div>
      <% end %>
    </div>

    <% @appointment.gift_cards.each do |gift_card| %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">A small thank-you</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          We're sorry for the wait. Here's a gift card to <%= gift_card.merchant_name %>.
        </p>
        <div class="mt-3 rounded-xl bg-teal-50 dark:bg-teal-900/20 p-4 text-center">
          <p class="text-2xl font-bold text-teal-700 dark:text-teal-300">$<%= "%.2f" % (gift_card.amount_cents / 100.0) %></p>
          <% if gift_card.merchant_url.present? %>
            <a href="<%= gift_card.merchant_url %>" class="mt-2 inline-block rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-500" target="_blank" rel="noopener">
              Redeem
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <p class="text-center text-xs text-gray-400">
      This page updates automatically.
    </p>
  </div>
</div>
