<% if @morning.any? || @afternoon.any? %>
  <div id="appointments" aria-live="polite">
    <% if @morning.any? %>
      <section class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Morning</span>
          <span class="text-xs text-gray-300 dark:text-gray-600"><%= @morning.size %> appointments</span>
          <div class="flex-1 border-t border-gray-200 dark:border-gray-700"></div>
        </div>
        <div class="space-y-3">
          <% @morning.each do |appointment| %>
            <%= render AppointmentRowComponent.new(appointment: appointment) %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @lunch_configured %>
      <div class="my-6 flex items-center gap-4">
        <div class="flex-1 border-t border-dashed border-amber-300 dark:border-amber-700"></div>
        <div class="flex items-center gap-2 rounded-full bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 px-4 py-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-amber-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-xs font-semibold text-amber-700 dark:text-amber-300">Lunch</span>
          <span class="text-xs text-amber-600 dark:text-amber-400"><%= @lunch_start %> – <%= @lunch_end %></span>
        </div>
        <div class="flex-1 border-t border-dashed border-amber-300 dark:border-amber-700"></div>
      </div>
    <% end %>

    <% if @afternoon.any? %>
      <section>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Afternoon</span>
          <span class="text-xs text-gray-300 dark:text-gray-600"><%= @afternoon.size %> appointments</span>
          <div class="flex-1 border-t border-gray-200 dark:border-gray-700"></div>
        </div>
        <div class="space-y-3">
          <% @afternoon.each do |appointment| %>
            <%= render AppointmentRowComponent.new(appointment: appointment) %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <%= render EmptyStateComponent.new(
    title: "No appointments for #{@selected_date == Date.current ? 'today' : @selected_date.strftime('%A, %B %-d')}",
    description: "Create an appointment or connect an integration to sync from your booking system."
  ) %>
<% end %>
