<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">
            <%= @selected_date == Date.current ? "Today" : @selected_date.strftime("%A, %B %-d") %>
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= @selected_date.strftime("%B %-d, %Y") %></p>
        </div>
        <div class="flex items-center gap-3">
          <% if @providers.count > 1 %>
            <select onchange="window.location.href=this.value" class="rounded-xl border-0 bg-gray-100 dark:bg-gray-700 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-teal-600">
              <option value="<%= root_path(date: @selected_date.iso8601, view: @view_mode) %>" <%= 'selected' if @selected_provider_id.blank? %>>All Providers</option>
              <% @providers.each do |provider| %>
                <option value="<%= root_path(date: @selected_date.iso8601, view: @view_mode, provider_id: provider.id) %>" <%= 'selected' if @selected_provider_id.to_s == provider.id.to_s %>><%= provider.display_name %></option>
              <% end %>
            </select>
          <% end %>
          <button onclick="window.print()" class="no-print rounded-xl bg-gray-100 dark:bg-gray-700 p-2.5 text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-600 transition" title="Print schedule">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
            </svg>
          </button>
          <%= link_to new_appointment_path, class: "no-print rounded-2xl bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 transition" do %>
            + Appointment
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <!-- Date navigation -->
  <%= render DateNavComponent.new(dates: @week_dates, selected_date: @selected_date, day_counts: @day_counts, view_mode: @view_mode, provider_id: @selected_provider_id) %>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 pt-4">
    <%= render BaaBannerComponent.new(tenant: current_user.tenant) %>
  </div>

  <%= turbo_stream_from "tenant_#{current_user.tenant_id}_appointments" %>

  <main class="mx-auto max-w-5xl px-4 py-4 sm:px-6" role="main" aria-label="Appointments">
    <% if @view_mode == "week" %>
      <%= render "dashboard/week_view" %>
    <% else %>
      <%= render "dashboard/list_view" %>
    <% end %>
  </main>
</div>
