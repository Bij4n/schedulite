<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- Header -->
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-lg px-4 py-4 sm:max-w-2xl sm:px-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Today</h1>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= Date.current.strftime("%A, %B %-d") %></p>
        </div>
        <nav class="flex items-center gap-3" aria-label="User actions">
          <span class="text-xs text-gray-400"><%= current_user.full_name %></span>
          <%= link_to "Settings", settings_integrations_path, class: "text-xs text-gray-500 dark:text-gray-400 hover:text-teal-600", aria: { label: "Integration settings" } %>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-teal-600 hover:text-teal-500" %>
        </nav>
      </div>
    </div>
  </header>

  <!-- BAA reminder -->
  <%= render BaaBannerComponent.new(tenant: current_user.tenant) %>

  <!-- Subscribe to real-time appointment updates -->
  <%= turbo_stream_from "tenant_#{current_user.tenant_id}_appointments" %>

  <!-- Timeline -->
  <main class="mx-auto max-w-lg px-4 py-6 sm:max-w-2xl sm:px-6" role="main" aria-label="Today's appointments">
    <% if @appointments.any? %>
      <div id="appointments" class="space-y-3" aria-live="polite">
        <% @appointments.each do |appointment| %>
          <%= render AppointmentRowComponent.new(appointment: appointment) %>
        <% end %>
      </div>
    <% else %>
      <%= render EmptyStateComponent.new(
        title: "No appointments today",
        description: "When appointments are synced or added, they'll appear here."
      ) %>
    <% end %>
  </main>
</div>
