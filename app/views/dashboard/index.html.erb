<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Today</h1>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= Date.current.strftime("%A, %B %-d") %></p>
        </div>
        <%= link_to new_appointment_path, class: "rounded-xl bg-teal-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-teal-500" do %>
          + Appointment
        <% end %>
      </div>
    </div>
  </header>

  <div class="mx-auto max-w-2xl px-4 sm:px-6 pt-4">
    <%= render BaaBannerComponent.new(tenant: current_user.tenant) %>
  </div>

  <%= turbo_stream_from "tenant_#{current_user.tenant_id}_appointments" %>

  <main class="mx-auto max-w-2xl px-4 py-4 sm:px-6" role="main" aria-label="Today's appointments">
    <% if @appointments.any? %>
      <div id="appointments" class="space-y-3" aria-live="polite">
        <% @appointments.each do |appointment| %>
          <%= render AppointmentRowComponent.new(appointment: appointment) %>
        <% end %>
      </div>
    <% else %>
      <%= render EmptyStateComponent.new(
        title: "No appointments today",
        description: "Create an appointment or connect an integration to sync from your booking system."
      ) %>
    <% end %>
  </main>
</div>
