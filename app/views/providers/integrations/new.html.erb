<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to provider_path(@provider), class: "text-gray-400 hover:text-gray-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100">Connect Calendar for <%= @provider.display_name %></h1>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-lg px-4 py-6 sm:px-6 space-y-4">
    <% if @selected_type %>
      <!-- Credential form for selected type -->
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-1"><%= @selected_type[:name] %></h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Enter your calendar credentials below.</p>

        <%= form_with(url: provider_integrations_path(@provider), method: :post, class: "space-y-4") do %>
          <%= hidden_field_tag :adapter_type, @selected_type[:type] %>

          <% @selected_type[:fields].each do |field| %>
            <div>
              <%= label_tag "credentials[#{field}]", field.humanize.titleize, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <% if field.include?("secret") || field.include?("token") || field.include?("key") %>
                <%= password_field_tag "credentials[#{field}]", nil, required: true, placeholder: "Enter #{field.humanize.downcase}",
                  class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
              <% else %>
                <%= text_field_tag "credentials[#{field}]", nil, required: true, placeholder: "Enter #{field.humanize.downcase}",
                  class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
              <% end %>
            </div>
          <% end %>

          <button type="submit" class="w-full rounded-xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer">
            Connect <%= @selected_type[:name] %>
          </button>
        <% end %>
      </div>
    <% else %>
      <!-- Pick calendar type -->
      <% @calendar_types.each do |cal| %>
        <%= link_to new_provider_integration_path(@provider, type: cal[:type]),
          class: "block rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700 hover:border-teal-300 dark:hover:border-teal-700 transition" do %>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= cal[:name] %></h3>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Connect this provider's <%= cal[:name] %> to sync appointments</p>
        <% end %>
      <% end %>
    <% end %>
  </main>
</div>
