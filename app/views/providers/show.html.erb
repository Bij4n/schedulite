<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <%= link_to providers_path, class: "text-gray-400 hover:text-gray-600" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
          <% end %>
          <div>
            <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100"><%= @provider.display_name %></h1>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= @provider.patients.count %> assigned patients · <%= @provider.appointments.count %> total appointments</p>
          </div>
        </div>
        <%= link_to "Edit", edit_provider_path(@provider), class: "text-sm text-teal-600 hover:text-teal-500" %>
      </div>
    </div>
  </header>

  <!-- Week date nav for this provider -->
  <div class="border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <!-- Week arrows and month -->
      <div class="flex items-center justify-between py-2">
        <% prev_week = @week_start - 7.days %>
        <% next_week = @week_start + 7.days %>
        <%= link_to provider_path(@provider, date: prev_week.iso8601, view: @view_mode), class: "p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        <% end %>
        <span class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= @week_start.strftime("%B %Y") %></span>
        <%= link_to provider_path(@provider, date: next_week.iso8601, view: @view_mode), class: "p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        <% end %>
      </div>

      <!-- Day strip -->
      <div class="flex gap-1 pb-3">
        <% @week_dates.each do |date| %>
          <% is_selected = date == @selected_date %>
          <% is_today = date == Date.current %>
          <% count = @day_counts[date] || 0 %>
          <%= link_to provider_path(@provider, date: date.iso8601, view: @view_mode),
            class: "flex-1 min-w-[44px] rounded-xl px-2 py-2 text-center transition #{is_selected ? 'bg-teal-600 text-white' : is_today ? 'bg-teal-50 dark:bg-teal-900/20 text-teal-700 dark:text-teal-300' : 'hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400'}" do %>
            <div class="text-[10px] font-medium uppercase <%= 'text-teal-200' if is_selected %>"><%= date.strftime("%a") %></div>
            <div class="text-lg font-bold leading-tight"><%= date.day %></div>
            <div class="text-[10px] <%= 'text-teal-200' if is_selected %>"><%= count > 0 ? count : '' %></div>
          <% end %>
        <% end %>
      </div>

      <!-- View toggle -->
      <div class="flex gap-1 pb-3">
        <% %w[list week].each do |mode| %>
          <% active = @view_mode == mode %>
          <%= link_to mode.capitalize, provider_path(@provider, date: @selected_date.iso8601, view: mode),
            class: "rounded-lg px-3 py-1 text-xs font-#{active ? 'semibold' : 'medium'} #{active ? 'bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900' : 'text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'}" %>
        <% end %>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 space-y-6">
    <% if @view_mode == "week" %>
      <!-- Week grid -->
      <div class="overflow-x-auto">
        <div class="grid grid-cols-7 gap-2 min-w-[700px]">
          <% @week_dates.each do |date| %>
            <div class="rounded-xl <%= date == Date.current ? 'bg-teal-50/50 dark:bg-teal-900/10 border border-teal-200 dark:border-teal-800' : 'bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700' %> overflow-hidden">
              <div class="px-3 py-2 border-b border-gray-100 dark:border-gray-700 text-center">
                <div class="text-[10px] font-medium uppercase text-gray-400 dark:text-gray-500"><%= date.strftime("%a") %></div>
                <div class="text-sm font-bold <%= date == Date.current ? 'text-teal-600' : 'text-gray-900 dark:text-gray-100' %>"><%= date.day %></div>
              </div>
              <div class="p-2 space-y-1.5 min-h-[120px]">
                <% day_appts = @week_appointments[date] || [] %>
                <% if day_appts.any? %>
                  <% day_appts.each do |appt| %>
                    <%= link_to appointment_path(appt), class: "block rounded-lg p-2 text-xs transition hover:ring-1 hover:ring-teal-300 dark:hover:ring-teal-700 #{status_bg(appt.status)}" do %>
                      <div class="font-bold text-gray-900 dark:text-gray-100 tabular-nums"><%= appt.starts_at.strftime("%-l:%M %p") %></div>
                      <div class="text-gray-700 dark:text-gray-300 truncate mt-0.5"><%= appt.patient.display_name %></div>
                    <% end %>
                  <% end %>
                <% else %>
                  <div class="flex items-center justify-center h-full">
                    <span class="text-[10px] text-gray-300 dark:text-gray-600">No appts</span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- List view for selected day -->
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">
          <%= @selected_date == Date.current ? "Today's Appointments" : @selected_date.strftime("%A, %B %-d") %>
        </h3>
        <% if @today_appointments.any? %>
          <div class="space-y-2">
            <% @today_appointments.each do |appt| %>
              <%= link_to appointment_path(appt), class: "flex items-center justify-between text-sm py-3 px-3 -mx-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-xl transition" do %>
                <div class="flex items-center gap-4">
                  <span class="font-bold text-gray-900 dark:text-gray-100 tabular-nums w-20"><%= appt.starts_at.strftime("%-l:%M %p") %></span>
                  <span class="text-gray-700 dark:text-gray-300"><%= appt.patient.display_name %></span>
                </div>
                <%= render StatusPillComponent.new(status: appt.status) %>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400 py-4 text-center">No appointments for this day</p>
        <% end %>
      </div>
    <% end %>

    <!-- Upcoming appointments -->
    <% if @upcoming.any? %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Upcoming</h3>
        <div class="space-y-2">
          <% @upcoming.each do |appt| %>
            <%= link_to appointment_path(appt), class: "flex items-center justify-between text-sm py-2 px-2 -mx-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-lg transition" do %>
              <div class="flex items-center gap-3">
                <div class="text-xs text-gray-400 dark:text-gray-500 w-24">
                  <%= appt.starts_at.strftime("%b %-d") %>
                  <span class="font-medium text-gray-600 dark:text-gray-300"><%= appt.starts_at.strftime("%-l:%M %p") %></span>
                </div>
                <span class="text-gray-900 dark:text-gray-100"><%= appt.patient.display_name %></span>
              </div>
              <%= render StatusPillComponent.new(status: appt.status) %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Calendar Integration -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Calendar Sync</h3>
        <% if @provider.calendar_connected? %>
          <%= link_to provider_integration_path(@provider, @provider.calendar_integration),
            data: { turbo_method: :delete, turbo_confirm: "Disconnect this calendar?" },
            class: "text-xs text-red-500 hover:text-red-400" do %>Disconnect<% end %>
        <% else %>
          <%= link_to "Connect Calendar", new_provider_integration_path(@provider),
            class: "text-xs text-teal-600 hover:text-teal-500 font-medium" %>
        <% end %>
      </div>
      <% if @provider.calendar_connected? %>
        <% ci = @provider.calendar_integration %>
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full <%= ci.sync_status == :healthy ? 'bg-green-500' : ci.sync_status == :stale ? 'bg-amber-500' : 'bg-red-500 animate-pulse' %>"></div>
          <div>
            <p class="text-sm text-gray-900 dark:text-gray-100"><%= ci.adapter_type.humanize.titleize %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              <% if ci.last_synced_at %>Synced <%= time_ago_in_words(ci.last_synced_at) %> ago<% else %>Never synced<% end %>
            </p>
          </div>
        </div>
        <% if ci.sync_error.present? %>
          <div class="mt-2 rounded-lg bg-red-50 dark:bg-red-900/10 p-2 text-xs text-red-600 dark:text-red-400"><%= ci.sync_error.truncate(150) %></div>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-400">No calendar connected. Appointments must be added manually.</p>
      <% end %>
    </div>

    <!-- Availability Schedule -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Availability Schedule</h3>

      <% schedules = @provider.provider_schedules.order(:day_of_week) %>
      <% if schedules.any? %>
        <div class="space-y-2 mb-4">
          <% schedules.each do |sched| %>
            <div class="flex items-center justify-between text-sm py-2 px-2 -mx-2 rounded-lg">
              <div class="flex items-center gap-3">
                <span class="font-medium text-gray-900 dark:text-gray-100 w-24"><%= sched.day_name %></span>
                <span class="text-gray-500 dark:text-gray-400"><%= sched.start_time %> – <%= sched.end_time %></span>
                <span class="text-xs text-gray-400">(<%= sched.slot_duration_minutes %>min slots)</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium rounded-full px-2 py-0.5 <%= sched.approved? ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300' : sched.pending? ? 'bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300' : sched.status == 'rejected' ? 'bg-red-50 dark:bg-red-900/20 text-red-600' : 'bg-gray-100 dark:bg-gray-700 text-gray-500' %>">
                  <%= sched.status.capitalize %>
                </span>
                <% if sched.pending? && (current_user.owner? || current_user.admin?) %>
                  <%= link_to "Approve", approve_provider_schedule_path(@provider, sched), data: { turbo_method: :patch }, class: "text-xs text-teal-600 hover:text-teal-500" %>
                  <%= link_to "Reject", reject_provider_schedule_path(@provider, sched), data: { turbo_method: :patch }, class: "text-xs text-red-500 hover:text-red-400" %>
                <% end %>
                <%= link_to provider_schedule_path(@provider, sched), data: { turbo_method: :delete, turbo_confirm: "Remove this schedule?" }, class: "text-xs text-gray-400 hover:text-gray-300" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Add schedule form -->
      <details class="group">
        <summary class="text-xs text-teal-600 hover:text-teal-500 font-medium cursor-pointer">+ Add Availability</summary>
        <div class="mt-3">
          <%= form_with(model: ProviderSchedule.new, url: provider_schedules_path(@provider), class: "space-y-3") do |f| %>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <%= f.label :day_of_week, "Day", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
                <%= f.select :day_of_week, ProviderSchedule::DAY_NAMES.each_with_index.map { |name, i| [name, i] },
                  {}, class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
              </div>
              <div>
                <%= f.label :slot_duration_minutes, "Slot Duration", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
                <%= f.select :slot_duration_minutes, [["15 min", 15], ["30 min", 30], ["45 min", 45], ["60 min", 60]],
                  { selected: 30 }, class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <%= f.label :start_time, "Start", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
                <%= f.time_field :start_time, value: "09:00", class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
              </div>
              <div>
                <%= f.label :end_time, "End", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
                <%= f.time_field :end_time, value: "17:00", class: "mt-1 block w-full rounded-xl border-0 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600" %>
              </div>
            </div>
            <%= f.submit "Add", class: "w-full rounded-xl bg-teal-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
          <% end %>
        </div>
      </details>
    </div>

    <!-- Assigned patients -->
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 border border-gray-200 dark:border-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Assigned Patients (<%= @provider.patients.count %>)</h3>
      <% if @provider.patients.any? %>
        <div class="space-y-2">
          <% @provider.patients.each do |patient| %>
            <%= link_to patient_path(patient), class: "flex items-center justify-between text-sm py-2 px-2 -mx-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-lg transition" do %>
              <span class="font-medium text-gray-900 dark:text-gray-100"><%= patient.first_name %> <%= patient.last_name %></span>
              <span class="text-xs text-gray-400"><%= format_phone(patient.phone) %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">No patients assigned yet</p>
      <% end %>
    </div>
  </main>
</div>
