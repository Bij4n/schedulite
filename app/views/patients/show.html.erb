<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <%= link_to patients_path, class: "text-gray-400 hover:text-gray-600" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
          <% end %>
          <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100"><%= @patient.first_name %> <%= @patient.last_name %></h1>
        </div>
        <%= link_to "Edit", edit_patient_path(@patient), class: "text-sm text-teal-600 hover:text-teal-500" %>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-4 py-6 sm:px-6 space-y-4">
    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700">
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Phone</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100"><%= format_phone(@patient.phone) %></dd>
        </div>
        <% if @patient.email.present? %>
          <div class="flex justify-between">
            <dt class="text-gray-500 dark:text-gray-400">Email</dt>
            <dd class="font-medium text-gray-900 dark:text-gray-100"><%= @patient.email %></dd>
          </div>
        <% end %>
        <% if @patient.date_of_birth.present? %>
          <div class="flex justify-between">
            <dt class="text-gray-500 dark:text-gray-400">Date of Birth</dt>
            <dd class="font-medium text-gray-900 dark:text-gray-100"><%= @patient.date_of_birth %></dd>
          </div>
        <% end %>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Primary Provider</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">
            <% if @patient.primary_provider %>
              <%= link_to @patient.primary_provider.display_name, provider_path(@patient.primary_provider), class: "text-teal-600 hover:text-teal-500" %>
            <% else %>
              <span class="text-gray-400">Not assigned</span>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between items-center">
          <dt class="text-gray-500 dark:text-gray-400">SMS Consent</dt>
          <dd class="flex items-center gap-2">
            <span class="font-medium <%= @patient.sms_consent? ? 'text-teal-600' : 'text-amber-600' %>">
              <%= @patient.sms_consent? ? 'Opted In' : 'Pending' %>
            </span>
            <% unless @patient.sms_consent? %>
              <%= link_to send_consent_patient_path(@patient),
                data: { turbo_method: :post },
                class: "text-xs text-teal-600 hover:text-teal-500 underline" do %>
                Send Request
              <% end %>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between items-center">
          <dt class="text-gray-500 dark:text-gray-400">Card on File</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">
            <% if @patient.card_on_file? %>
              <span class="text-teal-600"><%= @patient.card_display %></span>
            <% else %>
              <span class="text-gray-400">No card</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl bg-white dark:bg-gray-800 p-5 shadow-sm ring-1 ring-gray-900/5 dark:ring-gray-700">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Appointment History</h3>
      <% if @appointments.any? %>
        <div class="space-y-2">
          <% @appointments.each do |appt| %>
            <%= link_to appointment_path(appt), class: "flex items-center justify-between text-sm py-2 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg px-2 -mx-2" do %>
              <div>
                <span class="text-gray-900 dark:text-gray-100"><%= appt.starts_at.strftime("%b %-d, %Y") %></span>
                <span class="text-gray-500 dark:text-gray-400 ml-2"><%= appt.starts_at.strftime("%-l:%M %p") %></span>
              </div>
              <%= render StatusPillComponent.new(status: appt.status) %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">No appointments yet</p>
      <% end %>
    </div>
  </main>
</div>
