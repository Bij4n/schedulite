<%= form_with(model: patient, url: url, class: "space-y-4") do |f| %>
  <% if patient.errors.any? %>
    <div class="rounded-xl bg-red-50 dark:bg-red-900/20 p-4 text-sm text-red-700 dark:text-red-400" role="alert">
      <% patient.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.text_field :first_name, required: true, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.text_field :last_name, required: true, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :phone, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.phone_field :phone, required: true, placeholder: "5551234567", class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.email_field :email, placeholder: "patient@example.com", class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
    <p class="mt-1 text-xs text-gray-400">Used to send calendar invites (Google/Apple Calendar)</p>
  </div>

  <div>
    <%= f.label :date_of_birth, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.date_field :date_of_birth, class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>

  <div>
    <%= f.label :primary_provider_id, "Primary Provider", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.select :primary_provider_id,
          Provider.order(:last_name).map { |p| [p.display_name, p.id] },
          { include_blank: "No assigned provider" },
          class: "mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm" %>
  </div>

  <div>
    <%= f.submit class: "w-full rounded-xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
  </div>
<% end %>
