<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <header class="sticky top-0 z-10 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border-b border-gray-100 dark:border-gray-700">
    <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6">
      <div class="flex items-center gap-3">
        <%= link_to provider_path(@provider), class: "text-gray-400 hover:text-gray-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100"><%= @provider.display_name %> — Running Late</h1>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-lg px-4 py-6 sm:px-6">
    <!-- Impact preview -->
    <div class="rounded-2xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-5 mb-6">
      <div class="flex items-center gap-3">
        <div class="text-3xl font-extrabold text-amber-700 dark:text-amber-300"><%= @affected_count %></div>
        <div>
          <p class="text-sm font-semibold text-amber-800 dark:text-amber-200">patients will be notified</p>
          <p class="text-xs text-amber-600 dark:text-amber-400">Remaining appointments for <%= @provider.display_name %> today</p>
        </div>
      </div>
    </div>

    <% if @templates.any? %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700">
        <%= form_with(url: delay_workflows_path, method: :post, class: "space-y-4") do %>
          <%= hidden_field_tag :provider_id, @provider.id %>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Message Template</label>
            <select name="template_id" required class="mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm">
              <% @templates.each do |t| %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">How many minutes behind?</label>
            <select name="delay_minutes" required class="mt-1 block w-full rounded-xl border-0 px-4 py-3 text-gray-900 dark:text-gray-100 dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-teal-600 sm:text-sm">
              <option value="10">10 minutes</option>
              <option value="15">15 minutes</option>
              <option value="20" selected>20 minutes</option>
              <option value="30">30 minutes</option>
              <option value="45">45 minutes</option>
              <option value="60">1 hour</option>
              <option value="90">1.5 hours</option>
            </select>
          </div>

          <div class="flex items-center gap-3">
            <input type="checkbox" name="gift_card_enabled" value="1" id="gift_card_enabled" class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-teal-600 focus:ring-teal-600">
            <label for="gift_card_enabled" class="text-sm text-gray-600 dark:text-gray-400">Send gift card to patients who wait</label>
          </div>

          <button type="submit" class="w-full rounded-xl bg-amber-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-500 cursor-pointer">
            Notify <%= @affected_count %> Patients Now
          </button>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">No workflow templates created yet.</p>
        <%= link_to "Create a Template", new_settings_workflow_template_path, class: "text-sm text-teal-600 hover:text-teal-500 font-medium" %>
      </div>
    <% end %>
  </main>
</div>
